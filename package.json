{
  "name": "left-hand-control",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- node scripts/nuxt-dev.mjs",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm test:unit && pnpm test:components",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:components": "vitest run --config vitest.components.config.ts",
    "test:components:watch": "vitest --config vitest.components.config.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "nuxt prepare",
    "tauri": "tauri",
    "tauri:dev": "dotenv -e .env -- node scripts/tauri-dev.mjs",
    "tauri:build": "cross-env NO_STRIP=true tauri build"
  },
  "dependencies": {
    "@nuxt/ui": "^4.7.1",
    "@tauri-apps/api": "^2.11.0",
    "js-yaml": "^4.1.1",
    "nuxt": "4.4.2",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/lucide": "^1.2.105",
    "@nuxt/test-utils": "^4.0.3",
    "@tauri-apps/cli": "^2.11.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vue/test-utils": "^2.4.10",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "packageManager": "pnpm@9.12.0"
}
