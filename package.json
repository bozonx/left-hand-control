{
  "name": "left-hand-control",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm test:unit && pnpm test:components",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:components": "vitest run --config vitest.components.config.ts",
    "test:components:watch": "vitest --config vitest.components.config.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "nuxt prepare",
    "tauri": "tauri",
    "tauri:dev": "dotenv -e .env -- node scripts/tauri-dev.mjs",
    "tauri:build": "cross-env NO_STRIP=true tauri build"
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.1",
    "@tauri-apps/api": "^2.10.1",
    "js-yaml": "^4.1.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@nuxt/test-utils": "^4.0.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.25.0",
    "@eslint/js": "^9.25.0",
    "typescript-eslint": "^8.31.0",
    "eslint-plugin-vue": "^10.1.0",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.12.0"
}
