{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Left Hand Control",
  "version": "0.1.0",
  "identifier": "dev.bozonx.left-hand-control",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm generate",
    "devUrl": "http://localhost:3010",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "Left Hand Control",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost http://localhost:3010 ws://localhost:3011; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self' asset: http://asset.localhost data:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "webkit2gtk-4.1",
          "gtk3",
          "libappindicator3-1",
          "librsvg2-2",
          "libssl3",
          "libxdo3"
        ]
      }
    }
  }
}