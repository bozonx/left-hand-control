# Optional. Copy to `.env` to override dev defaults. Loaded by Node via
# `--env-file-if-exists=.env` in `pnpm dev` / `pnpm tauri:dev`, so a missing
# `.env` is fine — every variable below has a sensible default.

# Override the directory that the desktop app uses for config + data in
# debug builds. Path is relative to the process CWD (or absolute).
# Default: `<repo>/.dev-files` (resolved at compile time, so it works
# regardless of where you launch the binary from). Has no effect in
# release builds — production uses the OS-standard app config / data dirs.
# LHC_DEV_DIR=./.dev-files

# Dev server port. Must match what Tauri's devUrl points at; the
# `scripts/tauri-dev.mjs` wrapper takes this value and rewrites both the
# devUrl and the dev-only CSP, so changing it here is enough.
# LHC_DEV_PORT=3000
