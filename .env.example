# Copy to `.env` to enable. Read by Vite at build / dev time.

# When `true`, at startup the app ignores the layout in config.json and
# seeds the UI with the bundled Ivan K's preset (public/ivank-layout.yaml).
# Global settings (inputDevicePath, timeouts, ...) from config.json are
# preserved. Saving behaves as usual: any edit in the UI is written back
# to config.json, overwriting the previous user layout on the next
# auto-save. Useful for iterating on the bundled preset — do NOT enable
# in production installs.
VITE_LHC_FORCE_IVANK=false

# Dev server ports (must match src-tauri/tauri.conf.json)
PORT=3000
