# Copy to `.env` to enable. Read by Vite at build / dev time.

# When `true`, the first-run picker is skipped and at startup the app
# immediately creates / overwrites a regular user layout file from the
# bundled Ivan K template (public/ivank-layout.yaml) and loads it.
# Global settings (inputDevicePath, timeouts, ...) from config.json are
# preserved. Useful for iterating on the template — do NOT enable in
# production installs.
VITE_LHC_FORCE_IVANK=false

# Dev server ports (must match src-tauri/tauri.conf.json)
PORT=3000
