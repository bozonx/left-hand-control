# Copy to `.env` to enable. Only read in dev mode (`pnpm dev` / `pnpm tauri:dev`).

# When `true`, the app ignores the persisted user config on startup and
# seeds state from `public/default-layers.yaml` instead. Saving behaves as
# usual — any edit in the UI is written back to the normal config file, so
# after the first change the on-disk config reflects the YAML + your edits.
# Useful for iterating on the default layout.
VITE_LHC_USE_DEFAULTS=false
