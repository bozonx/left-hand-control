# Copy to `.env` to enable. Only read in dev mode (`pnpm dev` / `pnpm tauri:dev`).

# When `true`, the app ignores the persisted user config on startup and
# seeds state from `public/default-layers.yaml` instead. Changes made in the
# UI are NOT persisted to disk in this mode, so the next launch starts fresh
# from the YAML again. Useful for iterating on the default layout.
VITE_LHC_USE_DEFAULTS=false
